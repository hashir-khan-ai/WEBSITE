				<article id="restaurants" class="industry-detail reveal-on-scroll" style="border-top:1px solid var(--color-hairline);padding-top:64px;margin-top:48px;">
					<div class="industry-detail-header">
						<span class="card-meta-tag mono">INDUSTRY_05 // RESTAURANTS</span>
						<h2>Restaurants & Hospitality</h2>

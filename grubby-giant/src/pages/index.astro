	<!-- Live Terminal & Calculator Interactive Scripts -->
	<script is:inline>
		// --- Live Workflow Terminal Animation ---
		const logSequences = [
			{ tag: 'agent.init', level: 'info', msg: 'Initializing Agent workflow: Lead Qualifier v2.4...' },
			{ tag: 'db.query', level: 'info', msg: 'Fetching incoming customer inquiries from database...' },
			{ tag: 'agent.process', level: 'working', msg: 'Processing inquiry from Sarah (SarahMitchell@dentalclinic.com)...' },
			{ tag: 'agent.intent', level: 'info', msg: 'Intent identified: Dental scheduling, request for "BrightSmile Dental appointment".' },
			{ tag: 'llm.call', level: 'working', msg: 'Contextualizing calendar availability for Dr. Mitchell...' },
			{ tag: 'calendar.check', level: 'info', msg: 'Found open calendar slot: June 30 at 3:00 PM.' },
			{ tag: 'email.draft', level: 'info', msg: 'Drafting confirmation email & pre-qual questionnaire...' },
			{ tag: 'email.send', level: 'success', msg: 'Confirmation email dispatched. Saved front desk 45 mins.' },
			{ tag: 'agent.sleep', level: 'info', msg: 'Workflow completed. Idle for 30s.' }
		];

		const terminalBody = document.getElementById('terminalBody');
		let step = 0;

		function getTimestamp() {
			const now = new Date();
			return now.toTimeString().split(' ')[0];
		}

		function appendLog() {
			if (!terminalBody) return;
			
			if (step >= logSequences.length) {
				terminalBody.innerHTML = '';
				step = 0;
			}

			const log = logSequences[step];
			const row = document.createElement('div');
			row.className = 'terminal-log-row';
			
			let statusClass = 'info';
			if (log.level === 'working') statusClass = 'working';
			if (log.level === 'success') statusClass = 'success';

			row.innerHTML = `
				<span class="log-timestamp">${getTimestamp()}</span>
				<span class="log-tag">[${log.tag}]</span>
				<span class="log-status ${statusClass}">${log.level.toUpperCase()}</span>
				<span class="log-message">${log.msg}</span>
			`;

			terminalBody.appendChild(row);
			terminalBody.scrollTop = terminalBody.scrollHeight;
			step++;

			// Schedule next log
			let delay = 1800; // Default delay
			if (log.level === 'working') delay = 2400; // Let them see the processing
			if (log.tag === 'agent.sleep') delay = 4500; // Pause at sleep completed

			setTimeout(appendLog, delay);
		}

		// Start terminal animation after short delay
		setTimeout(appendLog, 800);

		// --- ROI Calculator Implementation ---
		const hoursSlider = document.getElementById('hoursSlider');
		const rateSlider = document.getElementById('rateSlider');
		const hoursVal = document.getElementById('hoursVal');
		const rateVal = document.getElementById('rateVal');
		const savingsDisplay = document.getElementById('savingsDisplay');
		const hoursReclaimedDisplay = document.getElementById('hoursReclaimedDisplay');

		function calculateSavings() {
			const hours = parseInt(hoursSlider.value);
			const rate = parseInt(rateSlider.value);
			
			// Show sliders value
			hoursVal.textContent = `${hours} hrs`;
			rateVal.textContent = `$${rate}/hr`;

			// Calculations: 4 weeks/month, AI automates ~80% of repetitive tasks
			const hoursReclaimed = Math.round(hours * 4);
			const monthlySavings = Math.round(hours * rate * 4 * 0.8);

			// Format currency
			const formattedSavings = new Intl.NumberFormat('en-US', {
				style: 'currency',
				currency: 'USD',
				maximumFractionDigits: 0
			}).format(monthlySavings);

			// Update DOM
			savingsDisplay.textContent = formattedSavings;
			hoursReclaimedDisplay.textContent = `${hoursReclaimed} hrs`;
		}

		if (hoursSlider && rateSlider) {
			hoursSlider.addEventListener('input', calculateSavings);
			rateSlider.addEventListener('input', calculateSavings);
			calculateSavings(); // Initial trigger
		}
	</script>
</Layout>

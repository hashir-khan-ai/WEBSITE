---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<!-- Hero Section -->
	<section class="hero-section">
		<div class="container">
			<a href="/industries" class="banner-marketing reveal-on-scroll">
				<span class="badge">New</span>
				<span>Explore industry-specific automation solutions</span>
				<svg viewBox="0 0 24 24" width="12" height="12" stroke="currentColor" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round" style="margin-left: 2px;"><line x1="7" y1="17" x2="17" y2="7"></line><polyline points="7,7 17,7 17,17"></polyline></svg>
			</a>
			
			<h1 class="hero-title reveal-on-scroll">Automate your business operations with AI workflows<span class="period">.</span></h1>
			<p class="hero-subtitle text-lead reveal-on-scroll">
				Custom AI agents that automate your workflows — and never forget a client, even if they call back in 6 months. Integrate with your current CRM and database systems.
			</p>
			
			<div class="hero-ctas reveal-on-scroll">
				<a href="https://calendly.com/hashirkhan" target="_blank" class="btn btn-primary" aria-label="Schedule Meeting">
					<svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
					<span>Schedule Meeting</span>
				</a>
   						<a href="https://wa.me/923165343521" target="_blank" class="btn btn-whatsapp animate-glow" aria-label="Chat on WhatsApp">
							<svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.514 2.266 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.502-5.724-1.455L0 24zm6.59-4.846c1.6.95 3.188 1.449 4.725 1.451 5.437 0 9.862-4.403 9.865-9.81.001-2.62-1.013-5.083-2.857-6.93C16.536 2.019 14.07 1.003 11.45 1.002 6.012 1.002 1.584 5.405 1.581 10.81c-.001 1.63.432 3.218 1.256 4.615l-.993 3.627 3.71-.973.103.062zM17.487 14.39c-.3-.15-1.774-.875-2.029-.968-.254-.093-.44-.139-.625.139-.186.278-.718.903-.88 1.088-.163.186-.325.208-.625.058-.3-.15-1.267-.467-2.414-1.493-.893-.796-1.495-1.78-1.67-2.08-.175-.3-.019-.463.13-.612.134-.133.3-.347.45-.52.149-.174.199-.297.299-.497.1-.2.05-.375-.025-.524-.075-.15-.625-1.505-.856-2.063-.225-.542-.472-.468-.648-.477-.168-.008-.36-.01-.552-.01-.192 0-.505.072-.77.36-.264.288-1.009.986-1.009 2.404s1.033 2.788 1.177 2.98c.145.195 2.033 3.103 4.925 4.35.688.297 1.224.474 1.643.607.69.219 1.319.19 1.815.115.553-.083 1.774-.725 2.024-1.425.25-.7.25-1.298.175-1.425-.076-.127-.26-.203-.56-.353z"/></svg>
							<span>WhatsApp Chat</span>
						</a>
						<a href="https://mail.google.com/mail/?view=cm&fs=1&to=hashirmehmoodkhan.pk@gmail.com" target="_blank" class="btn btn-email-gmail animate-glow" aria-label="Email Us">
							<svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
							<span>Email Me</span>
						</a>
						<a href="https://calendly.com/hashirkhan" target="_blank" class="btn btn-calendly animate-glow" aria-label="Book a Call">
							<svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
							<span>Book Call</span>
						</a>
					</div>
			
			<!-- Live Animated Workflow Terminal -->
			<div class="terminal-wrapper">
				<div class="terminal-header">
					<div class="terminal-buttons">
						<span class="terminal-btn red"></span>
						<span class="terminal-btn yellow"></span>
						<span class="terminal-btn green"></span>
					</div>
					<div class="terminal-title mono">workflow-agent.log</div>
					<div style="width: 32px;"></div>
				</div>
				<div class="terminal-body mono" id="terminalBody">
					<div class="terminal-body-wrap">
						<span id="terminalLine"></span><span class="terminal-cursor"></span>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Stats Bar -->
	<section class="stats-bar reveal-on-scroll">
		<div class="container">
			<div class="stats-grid">
				<div class="stat-item">
					<span class="stat-val" data-target="50">0+</span>
					<span class="stat-lbl">Automations Deployed</span>
				</div>
				<div class="stat-item">
					<span class="stat-val" data-target="12">0+</span>
					<span class="stat-lbl">Industries Served</span>
				</div>
				<div class="stat-item">
					<span class="stat-val" data-target="97">0%</span>
					<span class="stat-lbl">Client Satisfaction</span>
				</div>
				<div class="stat-item">
					<span class="stat-val" data-target="85">0+</span>
					<span class="stat-lbl">Hours Saved / Month</span>
				</div>
			</div>
			<p style="text-align:center;font-size:0.75rem;color:var(--color-mute);margin-top:16px;">Aggregate figures across active deployments as of mid-2026. Results vary by project scope.</p>
		</div>
	</section>

	<!-- Problem / Pain Point Section -->
	<section class="section-padding reveal-on-scroll" style="border-top: 1px solid var(--color-hairline); background-color: var(--color-canvas-soft);">
		<div class="container">
			<div class="section-header" style="max-width: 700px;">
				<span class="section-eyebrow">The Hidden Cost</span>
				<h2>Your Business Is Losing Customers Without Knowing It<span class="period">.</span></h2>
			</div>
			<div style="text-align: center; max-width: 620px; margin: 0 auto;">
				<p style="color: var(--color-body); font-size: 1.05rem; line-height: 1.7; margin-bottom: 24px;">
					A client calls back after weeks or months. Your team doesn't recognize them. They dig through old notes while the customer feels forgotten. That hesitation is enough to lose the deal.
				</p>
				<p style="color: var(--color-ink); font-size: 1.2rem; font-weight: 600; letter-spacing: -0.02em;">
					We fix that — permanently.
				</p>
			</div>
		</div>
	</section>

	<!-- Services Section (Preview) -->
	<section id="services" class="section-padding reveal-on-scroll">
		<div class="container">
			<div class="section-header">
				<span class="section-eyebrow">Capabilities</span>
				<h2>Services we provide<span class="period">.</span></h2>
				<p>We build production-ready agentic systems tailored to your tools and goals, replacing overhead with autonomous automation.</p>
			</div>
			
			<div class="services-grid services-preview-grid">
				<div class="card-marketing reveal-on-scroll">
					<div class="card-icon-container">
						<svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
					</div>
					<span class="card-meta-tag mono">AGENT_TYPE_01 // HELP_DESK</span>
					<h3>AI Customer Support Chatbots</h3>
					<p>Intelligent, context-aware bots trained on your internal documentation to resolve customer issues and guide inquiries 24/7 without manual support overhead.</p>
				</div>
				<div class="card-marketing reveal-on-scroll">
					<div class="card-icon-container">
						<svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"></polygon></svg>
					</div>
					<span class="card-meta-tag mono">AGENT_TYPE_02 // LEADS</span>
					<h3>Lead Qualification & Management</h3>
					<p>Automate incoming prospect filtering. Qualify prospects by intent, enrich company profile info via APIs, and automatically distribute leads to sales agents in your CRM.</p>
				</div>
				<div class="card-marketing reveal-on-scroll">
					<div class="card-icon-container">
						<svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
					</div>
					<span class="card-meta-tag mono">AGENT_TYPE_03 // CALENDAR</span>
					<h3>Appointment Scheduling Automation</h3>
					<p>End the email back-and-forth. Our agents resolve availability conflicts, propose slots, and automatically book meetings in Calendly or Google Calendar directly inside chats.</p>
				</div>
				<div class="card-marketing reveal-on-scroll">
					<div class="card-icon-container">
						<svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"></ellipse><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"></path><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"></path></svg>
					</div>
					<span class="card-meta-tag mono">AGENT_TYPE_04 // MEMORY</span>
					<h3>Client Recall Engine</h3>
					<p>A persistent memory layer built into your AI agent. When a client returns after a week, a month, or a year, your agent responds instantly with full context — no re-asking, no digging through docs, no lost customers.</p>
				</div>
			</div>
			<div class="preview-cta">
				<a href="/services" class="btn btn-secondary">View all services <span style="display:inline-block;margin-left:4px;">→</span></a>
			</div>
		</div>
	</section>

	<!-- How the Agent Thinks - Animated SVG Diagram -->
	<section id="how-it-works" class="agent-flow-section reveal-on-scroll">
		<div class="container">
			<div class="section-header">
				<span class="section-eyebrow">Agentic Architecture</span>
				<h2>How the agent thinks<span class="period">.</span></h2>
				<p>A continuous autonomous loop — trigger, reason, act, learn — powering your operations 24/7.</p>
			</div>

			<div class="agent-flow-grid">
				<div class="agent-grid-item" data-step="1">
					<div class="agent-node trigger">
						<span class="agent-icon">⚡</span>
						<span class="agent-label">Inbound Trigger</span>
					</div>
					<p style="font-size:0.8rem;color:var(--color-mute);margin-top:8px;">WhatsApp, Email, Webhook</p>
				</div>
				<div class="agent-grid-item" data-step="2">
					<div class="agent-node reasoning">
						<span class="agent-icon">🧠</span>
						<span class="agent-label">AI Reasoning</span>
					</div>
					<p style="font-size:0.8rem;color:var(--color-mute);margin-top:8px;">Intent classification + Context</p>
				</div>
				<div class="agent-grid-item" data-step="3">
					<div class="agent-node tool">
						<span class="agent-icon">🔧</span>
						<span class="agent-label">Tool Calls</span>
					</div>
					<p style="font-size:0.8rem;color:var(--color-mute);margin-top:8px;">CRM / Calendar / Database</p>
				</div>
				<div class="agent-grid-item" data-step="4">
					<div class="agent-node action">
						<span class="agent-icon">✅</span>
						<span class="agent-label">Action + Loop</span>
					</div>
					<p style="font-size:0.8rem;color:var(--color-mute);margin-top:8px;">Execute → Confirm → Re-trigger</p>
				</div>
			</div>

			<div class="svg-flow-container">
				<svg viewBox="0 0 800 60" fill="none" xmlns="http://www.w3.org/2000/svg">
					<defs>
						<linearGradient id="flowGrad" x1="0" y1="0" x2="1" y2="0">
							<stop offset="0%" stop-color="#a855f7" stop-opacity="0.1"/>
							<stop offset="50%" stop-color="#06b6d4" stop-opacity="0.4"/>
							<stop offset="100%" stop-color="#a855f7" stop-opacity="0.1"/>
						</linearGradient>
						<radialGradient id="dotGlow">
							<stop offset="0%" stop-color="#a855f7" stop-opacity="0.8"/>
							<stop offset="100%" stop-color="#a855f7" stop-opacity="0"/>
						</radialGradient>
					</defs>
					<rect x="0" y="24" width="800" height="12" rx="6" fill="url(#flowGrad)"/>
					<circle id="flowDot" cx="0" cy="30" r="8" fill="url(#dotGlow)">
						<animate attributeName="cx" values="0;800" dur="4s" repeatCount="indefinite"/>
					</circle>
					<circle cx="0" cy="30" r="4" fill="white" opacity="0.9">
						<animate attributeName="cx" values="0;800" dur="4s" repeatCount="indefinite"/>
					</circle>
				</svg>
			</div>
		</div>
	</section>

	<!-- Case Studies Section (Dark Polarity Flip — Preview) -->
	<section id="projects" class="section-padding showcase-band-dark reveal-on-scroll">
		<div class="container">
			<div class="section-header">
				<span class="section-eyebrow">Case Studies</span>
				<h2>Featured projects and results<span class="period">.</span></h2>
				<p>See how our tailored AI Agent systems solve real bottleneck problems and deliver measurable ROI to businesses.</p>
			</div>
			
			<div class="case-studies-preview-grid">
				<div class="case-study-card reveal-on-scroll">
					<div class="case-study-top">
						<div class="case-study-title-area">
							<h3>Dental Clinic Automation</h3>
							<div class="case-study-meta mono">Dr. Sarah Mitchell | Clinic Director | BrightSmile Dental | June 2026</div>
						</div>
						<div class="case-study-rating">★★★★★</div>
					</div>
					<div class="case-study-results">
						<div class="results-tags">
							<span class="result-tag-pill">70% Fewer Phone Calls</span>
							<span class="result-tag-pill">15+ Hours Saved/Week</span>
							<span class="result-tag-pill">Patient Satisfaction +40%</span>
						</div>
					</div>
				</div>
				<div class="case-study-card reveal-on-scroll">
					<div class="case-study-top">
						<div class="case-study-title-area">
							<h3>Immigration Consulting Assistant</h3>
							<div class="case-study-meta mono">James Chen | Managing Partner | GlobalVisa Advisors | May 2026</div>
						</div>
						<div class="case-study-rating">★★★★★</div>
					</div>
					<div class="case-study-results">
						<div class="results-tags">
							<span class="result-tag-pill">85% Inquiries Handled by AI</span>
							<span class="result-tag-pill">Lead Conversion +60%</span>
							<span class="result-tag-pill">$8,000/Month Saved</span>
						</div>
					</div>
				</div>
			</div>
			<div class="preview-cta">
				<a href="/projects" class="btn btn-secondary" style="border-color:rgba(255,255,255,0.15);color:white;">View all projects <span style="display:inline-block;margin-left:4px;">→</span></a>
			</div>
		</div>
	</section>

	<!-- Tech Stack & Integrations -->
	<section class="section-padding reveal-on-scroll" style="border-top: 1px solid var(--color-hairline);">
		<div class="container">
			<div class="section-header">
				<span class="section-eyebrow">Technology Stack</span>
				<h2>Tools and platforms we work with<span class="period">.</span></h2>
				<p>We build on proven infrastructure — from frontier AI models to battle-tested automation and data layers.</p>
			</div>
			
			<div class="stack-category">
				<h3 class="stack-category-title">AI Models</h3>
				<div class="stack-grid">
					<div class="stack-item"><span class="stack-name">OpenRouter</span><span class="stack-desc">Multi-model gateway</span></div>
					<div class="stack-item"><span class="stack-name">OpenAI</span><span class="stack-desc">GPT-4o / o3</span></div>
					<div class="stack-item"><span class="stack-name">Claude</span><span class="stack-desc">Claude 4 Sonnet / Opus</span></div>
					<div class="stack-item"><span class="stack-name">Gemini</span><span class="stack-desc">Gemini 2.5 Pro</span></div>
				</div>
			</div>
			
			<div class="stack-category">
				<h3 class="stack-category-title">Automation & Data</h3>
				<div class="stack-grid">
					<div class="stack-item"><span class="stack-name">n8n</span><span class="stack-desc">Workflow orchestration</span></div>
					<div class="stack-item"><span class="stack-name">Supabase</span><span class="stack-desc">Backend & real-time DB</span></div>
					<div class="stack-item"><span class="stack-name">PostgreSQL</span><span class="stack-desc">Relational data layer</span></div>
					<div class="stack-item"><span class="stack-name">Docker</span><span class="stack-desc">Containerized deployment</span></div>
				</div>
			</div>
			
			<div class="stack-category">
				<h3 class="stack-category-title">Integrations & Deploy</h3>
				<div class="stack-grid">
					<div class="stack-item"><span class="stack-name">WhatsApp Business API</span><span class="stack-desc">Messaging channel</span></div>
					<div class="stack-item"><span class="stack-name">Stripe</span><span class="stack-desc">Payment processing</span></div>
					<div class="stack-item"><span class="stack-name">Google Workspace</span><span class="stack-desc">Calendar / Email / Sheets</span></div>
					<div class="stack-item"><span class="stack-name">Slack</span><span class="stack-desc">Team notifications</span></div>
					<div class="stack-item"><span class="stack-name">Notion</span><span class="stack-desc">Knowledge base sync</span></div>
					<div class="stack-item"><span class="stack-name">Vercel / Netlify</span><span class="stack-desc">Hosting & edge functions</span></div>
					<div class="stack-item"><span class="stack-name">Cloudflare</span><span class="stack-desc">DNS / CDN / R2</span></div>
					<div class="stack-item"><span class="stack-name">REST / Webhooks</span><span class="stack-desc">Custom API integration</span></div>
				</div>
			</div>
			
			<div class="preview-cta">
				<p style="color:var(--color-mute);font-size:0.9rem;">Every stack is tailored per project. We select the right tools for your use case, not the other way around.</p>
			</div>
		</div>
	</section>

	<!-- Industries We Serve -->
	<section id="industries" class="section-padding showcase-band-dark reveal-on-scroll">
		<div class="container">
			<div class="section-header">
				<span class="section-eyebrow">Industries</span>
				<h2>AI automation built for your vertical<span class="period">.</span></h2>
				<p>We tailor every agent to the workflows, compliance needs, and pain points of your specific industry.</p>
			</div>
			
			<div class="industries-grid">
				<div class="industry-card reveal-on-scroll">
					<div class="industry-icon">
						<svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path></svg>
					</div>
					<h3>Real Estate</h3>
					<p>Automate property inquiry qualification, schedule viewings 24/7, follow up on warm leads automatically via WhatsApp.</p>
					<a href="/industries#real-estate" class="industry-link">Learn more</a>
				</div>
				<div class="industry-card reveal-on-scroll">
					<div class="industry-icon">
						<svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"></path></svg>
					</div>
					<h3>Healthcare</h3>
					<p>Book patient appointments, send reminders, triage intake forms, and reduce no-shows — all within HIPAA-aware workflows.</p>
					<a href="/industries#healthcare" class="industry-link">Learn more</a>
				</div>
				<div class="industry-card reveal-on-scroll">
					<div class="industry-icon">
						<svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
					</div>
					<h3>Legal & Law Firms</h3>
					<p>Qualify client intakes, automate consultation scheduling, manage document requests via secure AI chatbots.</p>
					<a href="/industries#legal" class="industry-link">Learn more</a>
				</div>
				<div class="industry-card reveal-on-scroll">
					<div class="industry-icon">
						<svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
					</div>
					<h3>Restaurants</h3>
					<p>Handle reservation calls, manage waitlists, send promotions, and collect feedback autonomously through voice and chat.</p>
					<a href="/industries#restaurants" class="industry-link">Learn more</a>
				</div>
				<div class="industry-card reveal-on-scroll">
					<div class="industry-icon">
						<svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"></polygon></svg>
					</div>
					<h3>Ecommerce</h3>
					<p>Handle order inquiries, returns automation, abandoned cart recovery, and real-time inventory checks via AI agents.</p>
					<a href="/industries#ecommerce" class="industry-link">Learn more</a>
				</div>

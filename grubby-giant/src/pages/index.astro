	<!-- Live Terminal, Chat Demo, Agent Flow & Calculator Scripts -->
	<script is:inline>
		// --- Live Workflow Terminal Animation (Typing effect) ---
		(function() {
			const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
			const terminalLine = document.getElementById('terminalLine');
			const terminalBody = document.getElementById('terminalBody');
			if (!terminalLine || !terminalBody) return;

			const lines = [
				{ tag: '[INIT]', cls: 'info', msg: 'Agent workflow initializing — Lead Qualifier v2.4' },
				{ tag: '[DB]', cls: 'info', msg: 'Fetched 3 new inquiries from message queue' },
				{ tag: '[PROCESS]', cls: 'working', msg: 'Processing: Sarah (sarah@brightsmile.com) — intent: scheduling' },
				{ tag: '[LLM]', cls: 'working', msg: 'Classifying intent: "booking" @ 97% confidence' },
				{ tag: '[CALENDAR]', cls: 'info', msg: 'Dr. Mitchell — open slot Jun 30, 3:00 PM' },
				{ tag: '[CRM]', cls: 'success', msg: 'Lead created — BrightSmile Dental, score 89' },
				{ tag: '[EMAIL]', cls: 'success', msg: 'Confirmation sent — saved 45 min of staff time' },
				{ tag: '[LOOP]', cls: 'info', msg: 'Cycle complete. Awaiting next trigger...' }
			];

			let lineIdx = 0;
			let charIdx = 0;
			let isDeleting = false;
			let isPaused = false;

			function typeLine() {
				if (isPaused) { setTimeout(typeLine, 600); isPaused = false; return; }
				const line = lines[lineIdx];
				const fullText = `${line.tag} [${line.cls.toUpperCase()}] ${line.msg}`;

				if (!isDeleting) {
					charIdx++;
					terminalLine.textContent = fullText.slice(0, charIdx);
					if (charIdx >= fullText.length) {
						if (reducedMotion) {
							setTimeout(nextLine, 100);
						} else {
							setTimeout(() => { isDeleting = true; typeLine(); }, 1800);
						}
						return;
					}
					setTimeout(typeLine, reducedMotion ? 5 : 20 + Math.random() * 30);
				} else {
					charIdx--;
					terminalLine.textContent = fullText.slice(0, charIdx);
					if (charIdx <= 0) {
						isDeleting = false;
						nextLine();
						return;
					}
					setTimeout(typeLine, reducedMotion ? 3 : 10);
				}
			}

			function nextLine() {
				lineIdx = (lineIdx + 1) % lines.length;
				charIdx = 0;
				isPaused = lineIdx === 0;
				setTimeout(typeLine, lineIdx === 0 ? 2500 : 400);
			}

			if (!reducedMotion) {
				setTimeout(typeLine, 600);
			} else {
				const all = lines.map(l => `${l.tag} [${l.cls.toUpperCase()}] ${l.msg}`).join('  //  ');
				terminalLine.textContent = all;
			}
		})();

		// --- Agent Flow Node Pulse Animation ---
		(function() {
			const items = document.querySelectorAll('.agent-grid-item');
			if (!items.length) return;
			let current = 0;
			const flowDot = document.getElementById('flowDot');
			function pulseStep() {
				items.forEach((el, i) => {
					el.classList.remove('visible');
					const node = el.querySelector('.agent-node');
					if (node) node.classList.remove('pulse');
				});
				items.forEach((el, i) => {
					if (i === current || i === (current + 1) % items.length) {
						el.classList.add('visible');
					}
				});
				const node = items[current].querySelector('.agent-node');
				if (node) node.classList.add('pulse');
				current = (current + 1) % items.length;
			}
			pulseStep();
			setInterval(pulseStep, 2000);
		})();

		// --- Chat Demo Animation ---
		(function() {
			const chatBody = document.getElementById('chatBody');
			if (!chatBody) return;

			const conversations = [
				{ user: 'Hey! I need help with booking appointments for my dental clinic.', ai: "I'd be happy to help! Let me check — are you looking to automate patient booking, reminders, or both? Also, which calendar system do you use?" },
				{ user: 'Both. We use Google Calendar. We get about 50 calls a day.', ai: "Great fit! I can set up an AI agent that integrates with Google Calendar, handles incoming calls/WhatsApp, books slots in real time, and sends automated reminders. Would you like me to prepare a custom quote?" },
				{ user: "Yes, please! What's the next step?", ai: "Perfect! I'll have Hashir prepare a tailored proposal. In the meantime, would you like to book a 15-min discovery call to walk through the setup?" }
			];

			let convIdx = 0;
			let step = 0;
			let msgCount = 1;

			function addMessage(text, type, delay) {
				setTimeout(() => {
					const div = document.createElement('div');
					div.className = `chat-message ${type}`;
					if (type === 'ai') div.innerHTML = `<span class="msg-tag">AI Lead Agent</span>${text}`;
					else div.textContent = text;
					chatBody.appendChild(div);
					chatBody.scrollTop = chatBody.scrollHeight;
				}, delay);
			}

			function showTyping(delay, duration) {
				const typing = document.createElement('div');
				typing.className = 'chat-typing';
				typing.innerHTML = '<span class="typing-dot"></span><span class="typing-dot"></span><span class="typing-dot"></span>';
				setTimeout(() => {
					chatBody.appendChild(typing);
					chatBody.scrollTop = chatBody.scrollHeight;
					setTimeout(() => typing.classList.add('active'), 50);
				}, delay);
				setTimeout(() => {
					typing.remove();
				}, delay + duration);
				return delay + duration;
			}

			function runConversation() {
				convIdx = 0;
				function playNext() {
					if (convIdx >= conversations.length) {
						setTimeout(() => {
							chatBody.querySelectorAll('.chat-message, .chat-typing').forEach(el => el.remove());
							msgCount = 1;
							addMessage("Hi! I'm Hashir's AI assistant. I can help qualify leads, check availability, and book appointments. How can I help you?", 'ai', 300);
							setTimeout(runConversation, 2000);
						}, 3000);
						return;
					}
					const c = conversations[convIdx];
					addMessage(c.user, 'user', 500);
					const tEnd = showTyping(1200, 2200);
					addMessage(c.ai, 'ai', tEnd + 200);
					convIdx++;
					setTimeout(playNext, tEnd + 3000);
				}
				setTimeout(playNext, 3000);
			}

			setTimeout(runConversation, 4000);
		})();

		// --- ROI Calculator Implementation ---
		const hoursSlider = document.getElementById('hoursSlider');
		const rateSlider = document.getElementById('rateSlider');
		const hoursVal = document.getElementById('hoursVal');
		const rateVal = document.getElementById('rateVal');
		const savingsDisplay = document.getElementById('savingsDisplay');
		const hoursReclaimedDisplay = document.getElementById('hoursReclaimedDisplay');

		function calculateSavings() {
			const hours = parseInt(hoursSlider.value);
			const rate = parseInt(rateSlider.value);
			
			hoursVal.textContent = `${hours} hrs`;
			rateVal.textContent = `$${rate}/hr`;

			const hoursReclaimed = Math.round(hours * 4);
			const monthlySavings = Math.round(hours * rate * 4 * 0.8);

			const formattedSavings = new Intl.NumberFormat('en-US', {
				style: 'currency',
				currency: 'USD',
				maximumFractionDigits: 0
			}).format(monthlySavings);

			savingsDisplay.textContent = formattedSavings;
			hoursReclaimedDisplay.textContent = `${hoursReclaimed} hrs`;
		}

		if (hoursSlider && rateSlider) {
			hoursSlider.addEventListener('input', calculateSavings);
			rateSlider.addEventListener('input', calculateSavings);
			calculateSavings();
		}
	</script>
